(ns tests.handlers-test
  (:require phel.test :refer [deftest is])
  (:require phel.mock :refer [with-mocks mock])
  (:require app.handlers :as hdl)
  (:require app.persistence :as db))

;; Handlers take a request map and return a response map.
;; No HTTP, no Symfony, no real DB. Stub db/* at the boundary.

(def- stub-conn :fake-conn)

(deftest list-users-returns-200-and-rows
  (with-mocks [db/all-users (mock [{:id 1 :email "a@x" :name "A"}])]
    (let [resp (hdl/list-users {:attributes {:conn stub-conn}})]
      (is (= 200 (get resp :status)))
      (is (= [{:id 1 :email "a@x" :name "A"}] (get resp :body))))))

(deftest show-user-returns-200-when-found
  (with-mocks [db/find-user (mock {:tag :ok :user {:id 1 :email "a@x" :name "A"}})]
    (let [resp (hdl/show-user
                 {:attributes {:conn stub-conn
                               :match {:path-params {:id "1"}}}})]
      (is (= 200 (get resp :status)))
      (is (= "A" (get-in resp [:body :name]))))))

(deftest show-user-returns-404-when-missing
  (with-mocks [db/find-user (mock {:tag :not-found})]
    (let [resp (hdl/show-user
                 {:attributes {:conn stub-conn
                               :match {:path-params {:id "999"}}}})]
      (is (= 404 (get resp :status)))
      (is (= "not found" (get-in resp [:body :error]))))))

(deftest create-user-rejects-missing-fields
  (let [resp (hdl/create-user {:parsed-body {"email" "only@x"}
                               :attributes  {:conn stub-conn}})]
    (is (= 422 (get resp :status)))
    (is (contains? (get-in resp [:body :errors]) "name"))))

(deftest create-user-rejects-bad-email
  (let [resp (hdl/create-user {:parsed-body {"email" "nope" "name" "X"}
                               :attributes  {:conn stub-conn}})]
    (is (= 422 (get resp :status)))
    (is (contains? (get-in resp [:body :errors]) "email"))))

(deftest create-user-inserts-and-returns-201
  (with-mocks [db/insert-user! (mock 42)
               db/find-user    (mock {:tag :ok :user {:id 42 :email "g@x" :name "G"}})]
    (let [resp (hdl/create-user
                 {:parsed-body {"email" "g@x" "name" "G"}
                  :attributes  {:conn stub-conn}})]
      (is (= 201 (get resp :status)))
      (is (= 42 (get-in resp [:body :id]))))))
